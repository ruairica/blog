---
import { getCollection } from "astro:content";
import Card from "../components/Card.astro";
import Layout from "../layouts/Layout.astro";

const dateOptions = {
  day: "2-digit",
  month: "short",
  year: "numeric",
} as const;

const posts = await getCollection("blog");
---

<Layout tabTitle="Ruairi's Blog">
  <p class="site-description">
    Posting thoughts and things I learned recently in an attempt to help me remember them
  </p>

  <section class="posts-section">
    <div class="section-header">
      <h2>Posts</h2>
      <span class="post-count">{posts.length} articles</span>
    </div>
    <ul role="list" class="post-list">
      {
        posts
          .sort(
            (a, b) =>
              new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf()
          )
          .map((post) => (
            <Card
              href={"posts/" + post.slug}
              title={post.data.title}
              date={new Date(post.data.date).toLocaleString(
                "en-GB",
                dateOptions
              )}
            />
          ))
      }
    </ul>
  </section>

  <style>
    .site-description {
      font-size: 1.05rem;
      color: var(--text-secondary);
      margin: 0 0 2.5rem;
      line-height: 1.6;
    }

    .posts-section {
      margin-top: 0;
    }

    .section-header {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      margin-bottom: 1.5rem;
    }

    .section-header h2 {
      font-size: 0.8rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--text-muted);
      margin: 0;
      padding: 0;
      border: none;
    }

    .post-count {
      font-size: 0.8rem;
      color: var(--text-muted);
    }

    .post-list {
      display: flex;
      flex-direction: column;
      gap: 1px;
      padding: 0;
      margin: 0;
      border-radius: 12px;
      overflow: hidden;
      border: 1px solid var(--border);
    }

    @media (max-width: 720px) {
      .site-header {
        margin-bottom: 2rem;
        padding-bottom: 1.5rem;
      }

      .site-description {
        font-size: 0.95rem;
      }
    }
  </style>
</Layout>
