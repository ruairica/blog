---
import { getCollection } from "astro:content";
import Card from "../components/Card.astro";
import Layout from "../layouts/Layout.astro";

const dateOptions = {
  day: "2-digit", // Two-digit day
  month: "short", // Abbreviated month name
  year: "numeric", // Four-digit year
} as const;

const posts = await getCollection("blog"); // Astro.glob("./*.md");
---

<Layout tabTitle="Ruairi's Blog">
  <div class="industrial-header">
    <h1 class="header">
      <span class="bracket">[</span>
      Ruairi's Blog
      <span class="bracket">]</span>
    </h1>
  </div>

  <div class="blurb">
    <p>
      Posting thoughts and things I learned recently in an attempt to help me remember them 😊
    </p>
  </div>

  <div class="posts-container">
    <div class="container-label">
      <span>BLOG.POSTS</span>
      <span class="count">[{posts.length} ENTRIES]</span>
    </div>
    <ul role="list" class="link-card-grid">
      {
        posts
          .sort(
            (a, b) =>
              new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf()
          )
          .map((post) => (
            <Card
              href={"posts/" + post.slug}
              title={post.data.title}
              date={new Date(post.data.date).toLocaleString(
                "en-GB",
                dateOptions
              )}
            />
          ))
      }
    </ul>
  </div>

  <style>
    .industrial-header {
      position: relative;
      margin-bottom: 2rem;
      padding: 1rem 1.5rem;
      background: var(--bg-secondary);
      border: 2px solid var(--border-color);
      border-left: 4px solid rgb(var(--accent));
      box-shadow:
        0 0 0 1px rgba(var(--off-white), 0.05),
        0 4px 0 rgba(0, 0, 0, 0.3);
    }

    .header {
      font-size: clamp(1.5rem, 4vw, 2rem);
      margin: 0.5rem 0;
      text-align: center;
      position: relative;
      font-weight: 700;
      text-transform: none;
    }

    .bracket {
      color: rgb(var(--industrial-orange));
      font-weight: 700;
    }


    .blurb {
      margin-bottom: 3rem;
      padding: 1.5rem;
      background: var(--bg-secondary);
      border: 2px solid var(--border-color);
      border-left: 6px solid rgb(var(--industrial-orange));
      box-shadow: 0 4px 0 rgba(0, 0, 0, 0.2);
      position: relative;
    }

    .blurb p {
      margin: 0;
      font-size: 1.1rem;
      line-height: 1.6;
      color: var(--text-primary);
      text-transform: none;
      letter-spacing: normal;
    }

    .posts-container {
      position: relative;
      padding-top: 2rem;
    }

    .container-label {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1.5rem;
      padding: 0.8rem 1.2rem;
      background: var(--bg-secondary);
      border: 2px solid var(--border-color);
      border-top: 4px solid rgb(var(--accent));
      box-shadow: 0 2px 0 rgba(0, 0, 0, 0.3);
      font-weight: 700;
      font-size: 1.1rem;
      letter-spacing: 0.05em;
    }

    .container-label .count {
      color: rgb(var(--accent));
      font-size: 0.9rem;
    }

    .link-card-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.5rem;
      padding: 0;
      margin: 0;
    }

    @media (max-width: 720px) {
      .industrial-header {
        padding: 1rem;
      }

      .header {
        font-size: 1.5rem;
        margin: 0.5rem 0;
      }


      .blurb {
        padding: 1.2rem;
      }

      .blurb p {
        font-size: 0.9rem;
      }

      .container-label {
        flex-direction: column;
        gap: 0.5rem;
        text-align: center;
        font-size: 1rem;
      }

      .link-card-grid {
        grid-template-columns: 1fr;
        gap: 1rem;
      }
    }
  </style>
</Layout>
