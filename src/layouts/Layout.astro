---
import { ViewTransitions } from 'astro:transitions';
interface Props {
  tabTitle: string;
}

const { tabTitle } = Astro.props;

let isHomepage = tabTitle == "Ruairi's Blog";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <ViewTransitions />
    <meta charset="UTF-8" />
    <meta name="description" content={tabTitle} />
    <meta name="viewport" content="width=device-width" />
    {
      isHomepage ? (
        <meta
          name="google-site-verification"
          content="ktYIw1-TmButE57uD47n43Ld_hhTcPoEwB3XFaxYMUA"
        />
      ) : null
    }
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link
      rel="icon"
      href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>✏️</text></svg>"
    />
    <meta name="generator" content={Astro.generator} />
    <title>{tabTitle}</title>
  </head>
  <body>
    <header class="site-nav">
      <div class="site-nav-inner">
        <a href="/" class="site-name">Ruairi's Blog</a>
      </div>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>
<style is:global>
  :root {
    --bg-primary: #09090b;
    --bg-surface: #18181b;
    --bg-elevated: #1f1f23;
    --border: #27272a;
    --border-hover: #3f3f46;
    --text-primary: #fafafa;
    --text-secondary: #a1a1aa;
    --text-muted: #71717a;
    --accent: #a78bfa;
    --accent-hover: #c4b5fd;
    --accent-subtle: rgba(167, 139, 250, 0.1);
  }

  html {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background: var(--bg-primary);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    padding: 0;
  }

  .site-nav {
    position: sticky;
    top: 0;
    z-index: 10;
    background: rgba(9, 9, 11, 0.8);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .site-nav-inner {
    max-width: 720px;
    margin: 0 auto;
    padding: 0.75rem 1.5rem;
  }

  .site-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: -0.01em;
  }

  .site-name:hover {
    color: var(--accent);
  }

  main {
    margin: auto;
    padding: 2.5rem 1.5rem 3rem;
    width: 720px;
    max-width: calc(100% - 2rem);
    color: var(--text-primary);
    font-size: 16px;
    line-height: 1.7;
  }

  pre {
    border-radius: 8px;
    padding: 1rem 1.25rem;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    overflow-x: auto;
    font-size: 0.875rem;
    line-height: 1.6;
  }

  code {
    font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', 'Consolas', monospace;
    background: var(--bg-surface);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    border: 1px solid var(--border);
    font-size: 0.875em;
  }

  pre code {
    background: none;
    border: none;
    padding: 0;
    border-radius: 0;
    font-size: inherit;
  }

  h1 {
    margin-top: 0;
    margin-bottom: 0;
    font-weight: 700;
    line-height: 1.2;
    color: var(--text-primary);
    letter-spacing: -0.02em;
  }

  h2, h3, h4, h5, h6 {
    color: var(--text-primary);
    font-weight: 600;
    letter-spacing: -0.01em;
    margin-top: 2em;
    margin-bottom: 0.75em;
  }

  h2 {
    font-size: 1.375rem;
    padding-bottom: 0.5em;
    border-bottom: 1px solid var(--border);
  }

  h3 {
    font-size: 1.125rem;
  }

  p {
    color: var(--text-secondary);
    margin: 0 0 1.25em;
  }

  ul, ol {
    color: var(--text-secondary);
    padding-left: 1.5em;
  }

  li {
    margin-bottom: 0.35em;
  }

  a {
    color: var(--accent);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  a:hover {
    color: var(--accent-hover);
  }

  strong {
    color: var(--text-primary);
    font-weight: 600;
  }

  hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2em 0;
  }

  blockquote {
    margin: 1.5em 0;
    padding: 0.75em 1.25em;
    border-left: 3px solid var(--accent);
    background: var(--accent-subtle);
    border-radius: 0 6px 6px 0;
  }

  blockquote p {
    margin: 0;
  }

  img {
    max-width: 100%;
    border-radius: 8px;
  }

  @media (max-width: 720px) {
    main {
      padding: 2rem 1rem;
    }
  }
</style>
