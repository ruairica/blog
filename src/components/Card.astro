---
interface Props {
	title: string;
	href: string;
	date: string;
}

const { href, title, date } = Astro.props;
---

<li class="link-card">
	<a href={href}>
		<div class="card-corner top-left"></div>
		<div class="card-corner top-right"></div>
		<div class="card-corner bottom-left"></div>
		<div class="card-corner bottom-right"></div>
		<div class="card-content">
			<h2>
				<span class="arrow">›</span>
				{title}
			</h2>
			<div class="date-badge">
				<span class="date-label">DATE:</span>
				<span class="date-value">{date}</span>
			</div>
		</div>
	</a>
</li>
<style>
	.link-card {
		list-style: none;
		display: flex;
		background: var(--bg-secondary);
		border: 2px solid var(--border-color);
		box-shadow:
			0 0 0 1px rgba(var(--off-white), 0.03),
			0 4px 0 rgba(0, 0, 0, 0.3);
		transition: all 0.3s ease;
		position: relative;
		overflow: hidden;
	}

	.link-card::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 4px;
		background: rgb(var(--metal-gray));
		transition: background 0.3s ease;
	}

	.link-card > a {
		width: 100%;
		text-decoration: none;
		line-height: 1.5;
		padding: 1.5rem;
		color: var(--text-primary);
		display: block;
		position: relative;
	}

	.card-corner {
		position: absolute;
		width: 10px;
		height: 10px;
		border: 2px solid rgb(var(--metal-gray));
		transition: border-color 0.3s ease;
	}

	.card-corner.top-left {
		top: 8px;
		left: 8px;
		border-right: none;
		border-bottom: none;
	}

	.card-corner.top-right {
		top: 8px;
		right: 8px;
		border-left: none;
		border-bottom: none;
	}

	.card-corner.bottom-left {
		bottom: 8px;
		left: 8px;
		border-right: none;
		border-top: none;
	}

	.card-corner.bottom-right {
		bottom: 8px;
		right: 8px;
		border-left: none;
		border-top: none;
	}

	.card-content {
		margin: 0.5rem 0;
	}

	h2 {
		margin: 0 0 1rem 0;
		font-size: 1.1rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.03em;
		color: var(--text-primary);
		transition: color 0.3s ease;
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.arrow {
		color: rgb(var(--accent));
		font-size: 1.5rem;
		font-weight: 900;
		transition: transform 0.3s ease;
		display: inline-block;
	}

	.date-badge {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.4rem 0.8rem;
		background: var(--bg-primary);
		border: 1px solid var(--border-color);
		font-size: 0.85rem;
		font-weight: 600;
	}

	.date-label {
		color: rgb(var(--metal-gray));
		letter-spacing: 0.05em;
	}

	.date-value {
		color: rgb(var(--accent));
		font-family: 'Courier New', monospace;
	}

	.link-card:is(:hover, :focus-within) {
		transform: translateY(-2px);
		border-color: rgb(var(--accent));
		box-shadow:
			0 0 0 1px rgb(var(--accent)),
			0 0 20px rgba(var(--accent), 0.3),
			0 6px 0 rgba(0, 0, 0, 0.3);
	}

	.link-card:is(:hover, :focus-within)::before {
		background: rgb(var(--accent));
	}

	.link-card:is(:hover, :focus-within) h2 {
		color: rgb(var(--accent));
	}

	.link-card:is(:hover, :focus-within) .arrow {
		transform: translateX(4px);
	}

	.link-card:is(:hover, :focus-within) .card-corner {
		border-color: rgb(var(--accent));
	}

	@media (max-width: 720px) {
		.link-card > a {
			padding: 1.2rem;
		}

		h2 {
			font-size: 1rem;
		}

		.date-badge {
			font-size: 0.8rem;
			padding: 0.3rem 0.6rem;
		}

		.card-corner {
			width: 8px;
			height: 8px;
		}
	}
</style>
